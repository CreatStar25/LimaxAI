---
// src/layouts/BaseLayout.astro
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { LOCALES } from '../i18n/ui';

const {
  title,
  currentLang,
  description = '',
  image = '',
  canonical = Astro.url.href,
  baiduSiteVerification = false,
} = Astro.props;

// 请将此处替换为您主站的 GA4 衡量 ID
const GA_MEASUREMENT_ID = 'G-58B3K5R6KY';

// 国内引擎：content-language 元标签（百度/360 依赖）
const contentLanguageMap: Record<string, string> = {
  'zh-cn': 'zh-CN',
  'zh-tw': 'zh-TW',
  'en': 'en-US',
  'es': 'es-ES', 'ar': 'ar', 'pt': 'pt-BR', 'id': 'id', 'ms': 'ms', 'fr': 'fr-FR',
  'ru': 'ru', 'hi': 'hi', 'ja': 'ja', 'de': 'de-DE', 'ko': 'ko-KR', 'tr': 'tr',
  'vi': 'vi', 'th': 'th', 'it': 'it-IT', 'fa': 'fa', 'nl': 'nl-NL', 'pl': 'pl',
  'sv': 'sv', 'uk': 'uk', 'ro': 'ro',
};
const contentLanguage = contentLanguageMap[currentLang] ?? 'en-US';

// 国际引擎：hreflang + x-default（Google/Bing），x-default 指向英文
const site = Astro.site?.href ?? 'https://blog.limaxai.com';
const baseUrl = site.endsWith('/') ? site.slice(0, -1) : site;
const pathname = Astro.url.pathname;
const pathWithoutLang = pathname.replace(/^\/[^/]+/, '') || '/';
// 非根路径统一带尾部斜杠，与站内链接（如 /about/、/tutorials/）一致，避免语言切换跳错
const pathSuffix = pathWithoutLang === '/' ? '/' : (pathWithoutLang.endsWith('/') ? pathWithoutLang : pathWithoutLang + '/');

const metaDescription = description || String(title || 'LimaxAI');
const rawCanonical = String(canonical || `${baseUrl}${Astro.url.pathname}`);
const canonicalUrl = (() => {
  if (rawCanonical.startsWith('http')) {
    const hasTrailing = rawCanonical.endsWith('/') || rawCanonical.includes('?') || rawCanonical.includes('#');
    return hasTrailing ? rawCanonical : rawCanonical + '/';
  }
  const path = rawCanonical.startsWith('/') ? rawCanonical : '/' + rawCanonical;
  const hasTrailing = path.endsWith('/') || path.includes('?') || path.includes('#');
  return `${baseUrl}${hasTrailing ? path : path + '/'}`;
})();
const absoluteImage = image
  ? (String(image).startsWith('http') ? String(image) : `${baseUrl}${String(image).startsWith('/') ? '' : '/'}${String(image)}`)
  : `${baseUrl}/favicon.svg`;
---

<html lang={currentLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    {baiduSiteVerification && <meta name="baidu-site-verification" content="codeva-NNhQvugjuQ" />}
    <meta http-equiv="content-language" content={contentLanguage} />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="LimaxAI" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={absoluteImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={absoluteImage} />

    {/* 国际引擎：hreflang，x-default 指向英文 */}
    {LOCALES.map((locale) => {
      const href = baseUrl + '/' + locale + pathSuffix;
      return <link rel="alternate" hreflang={locale} href={href} />;
    })}
    <link rel="alternate" hreflang="x-default" href={baseUrl + '/en' + pathSuffix} />

    {/* 百度统计（仅简中/繁中加载） */}
    {(currentLang === 'zh-cn' || currentLang === 'zh-tw') && (
      <script is:inline>
        var _hmt = _hmt || [];
        (function() {
          var hm = document.createElement('script');
          hm.src = 'https://hm.baidu.com/hm.js?cd3aae11bcdf5378a37885c4ed4e4d78';
          var s = document.getElementsByTagName('script')[0];
          s.parentNode.insertBefore(hm, s);
        })();
      </script>
    )}

    {/* ================= Google Analytics 4 开始 ================= */}
    <script
      type="text/partytown"
      async
      src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}
    ></script>
    <script type="text/partytown" define:vars={{ GA_MEASUREMENT_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', GA_MEASUREMENT_ID);
    </script>
    {/* ================= Google Analytics 4 结束 ================= */}

  </head>
  <body class="flex flex-col min-h-screen bg-gray-50 text-gray-900">

    {/* 导航栏：传入当前语言与路径后缀，以便语言切换时保持同一页面 */}
    <Header currentLang={currentLang} pathSuffix={pathSuffix} />

    {/* 主要内容区域 - slot 会被外部传入的内容替换 */}
    <main class="flex-grow">
      <slot />
    </main>

    {/* 底部栏：传入当前语种以同步多语种文案 */}
    <Footer currentLang={currentLang} />

  </body>
</html>
