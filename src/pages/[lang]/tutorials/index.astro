---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TutorialLayout from '../../../components/TutorialLayout.astro';
import { LOCALES } from '../../../i18n/ui';
import {
  getTutorialList,
  getTutorialArticle,
  getTutorialLabels,
  getFirstTutorialSlug,
} from '../../../lib/tutorials';

export async function getStaticPaths() {
  return LOCALES.map((lang) => {
    const slug = getFirstTutorialSlug(lang);
    const article = getTutorialArticle(slug, lang)!;
    const list = getTutorialList(lang);
    return {
      params: { lang },
      props: {
        currentLang: lang,
        slug,
        article,
        list: list.map((e) => ({ slug: e.slug, title: e.title })),
        labels: getTutorialLabels(lang),
      },
    };
  });
}

const { currentLang, slug, article, list, labels } = Astro.props;
const backToBlogByLocale: Record<string, string> = {
  en: 'Blog',
  'zh-cn': '博客',
  'zh-tw': '部落格',
  es: 'Blog',
  ar: 'المدونة',
  pt: 'Blog',
  id: 'Blog',
  ms: 'Blog',
  fr: 'Blog',
  ru: 'Блог',
  hi: 'ब्लॉग',
  ja: 'ブログ',
  de: 'Blog',
  ko: '블로그',
  tr: 'Blog',
  vi: 'Blog',
  th: 'บล็อก',
  it: 'Blog',
  fa: 'وبلاگ',
  nl: 'Blog',
  pl: 'Blog',
  sv: 'Blogg',
  uk: 'Блог',
  ro: 'Blog',
};
