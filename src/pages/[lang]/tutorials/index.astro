const tutorialSeoTitle = tutorialSeoTitleByLocale[currentLang] ?? tutorialSeoTitleByLocale.en;
---

<BaseLayout title={tutorialSeoTitle} description={article.intro} canonical={`${Astro.url.origin}/${currentLang}/tutorials/`} currentLang={currentLang}>
  <div class="bg-white border-b border-gray-100 py-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href={`/${currentLang}/`} class="text-sm text-gray-500 hover:text-blue-600 transition-colors">← {backToBlog}</a>
    </div>
  </div>
  <TutorialLayout currentLang={currentLang} slug={slug} article={article} list={list} labels={labels} />
</BaseLayout>
