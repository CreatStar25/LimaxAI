---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TutorialLayout from '../../../components/TutorialLayout.astro';
import { LOCALES } from '../../../i18n/ui';
import {
  getTutorialList,
  getTutorialArticle,
  getTutorialLabels,
} from '../../../lib/tutorials';

export async function getStaticPaths() {
  const paths: { params: { lang: string; slug: string }; props: object }[] = [];
  for (const lang of LOCALES) {
    const list = getTutorialList(lang);
    for (const entry of list) {
      const article = getTutorialArticle(entry.slug, lang);
      if (article) {
        paths.push({
          params: { lang, slug: entry.slug },
          props: {
            currentLang: lang,
            slug: entry.slug,
            article,
            list: list.map((e) => ({ slug: e.slug, title: e.title })),
            labels: getTutorialLabels(lang),
          },
        });
      }
    }
  }
  return paths;
}

const { currentLang, slug, article, list, labels } = Astro.props;
const backToBlogByLocale: Record<string, string> = {
  en: 'Blog',
  'zh-cn': '博客',
  'zh-tw': '部落格',
  es: 'Blog',
  ar: 'المدونة',
  pt: 'Blog',
  id: 'Blog',
  ms: 'Blog',
  fr: 'Blog',
  ru: 'Блог',
  hi: 'ब्लॉग',
  ja: 'ブログ',
  de: 'Blog',
  ko: '블로그',
  tr: 'Blog',
  vi: 'Blog',
  th: 'บล็อก',
  it: 'Blog',
  fa: 'وبلاگ',
  nl: 'Blog',
  pl: 'Blog',
  sv: 'Blogg',
  uk: 'Блог',
  ro: 'Blog',
};
const backToBlog = backToBlogByLocale[currentLang] ?? backToBlogByLocale.en;
---

<BaseLayout title={`${article.title} | LimaxAI`} description={article.intro} canonical={`${Astro.url.origin}/${currentLang}/tutorials/${slug}/`} currentLang={currentLang}>
  <div class="bg-white border-b border-gray-100 py-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href={`/${currentLang}/`} class="text-sm text-gray-500 hover:text-blue-600 transition-colors">← {backToBlog}</a>
    </div>
  </div>
  <TutorialLayout currentLang={currentLang} slug={slug} article={article} list={list} labels={labels} />
</BaseLayout>
