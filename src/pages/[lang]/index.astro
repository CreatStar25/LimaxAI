---
// src/pages/[lang]/index.astro
import { getCollection } from 'astro:content';
import BlogCard from '../../components/BlogCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getContent } from '../../i18n/content';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  
  const locales = [
      'en', 'zh-cn', 'zh-tw', 'es', 'ar', 'pt', 'id', 'ms', 'fr', 'ru', 
      'hi', 'ja', 'de', 'ko', 'tr', 'vi', 'th', 'it', 'fa', 'nl', 'pl', 
      'sv', 'uk', 'ro'
  ];

  return locales.map(lang => {
    const posts = allPosts.filter(post => post.data.lang === lang);
    const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
    
    return {
      params: { lang },
      props: { posts: sortedPosts, currentLang: lang },
    };
  });
}

const { posts, currentLang } = Astro.props;
const buildTime = new Date().toISOString();
const c = getContent(currentLang);
const blogCopy = c.blog;
const blogSeoTitleByLocale: Record<string, string> = {
  en: 'LimaxAI Blog | All-in-One AI Tool Platform',
  'zh-cn': 'LimaxAI 博客 | 一站式 AI 工具平台',
  'zh-tw': 'LimaxAI 部落格 | 一站式 AI 工具平台',
  es: 'Blog de LimaxAI | Plataforma integral de herramientas de IA',
  ar: 'مدونة LimaxAI | منصة أدوات ذكاء اصطناعي شاملة',
  pt: 'Blog da LimaxAI | Plataforma completa de ferramentas de IA',
  id: 'Blog LimaxAI | Platform alat AI all-in-one',
  ms: 'Blog LimaxAI | Platform alat AI semua-dalam-satu',
  fr: 'Blog LimaxAI | Plateforme tout-en-un d’outils IA',
  ru: 'Блог LimaxAI | Универсальная платформа ИИ-инструментов',
  hi: 'LimaxAI ब्लॉग | ऑल-इन-वन AI टूल प्लेटफ़ॉर्म',
  ja: 'LimaxAIブログ | オールインワンAIツールプラットフォーム',
  de: 'LimaxAI Blog | All-in-One KI-Tool-Plattform',
  ko: 'LimaxAI 블로그 | 올인원 AI 도구 플랫폼',
  tr: 'LimaxAI Blog | Hepsi Bir Arada Yapay Zeka Araç Platformu',
  vi: 'Blog LimaxAI | Nền tảng công cụ AI tất-cả-trong-một',
  th: 'บล็อก LimaxAI | แพลตฟอร์มเครื่องมือ AI แบบครบวงจร',
  it: 'Blog LimaxAI | Piattaforma all-in-one di strumenti AI',
  fa: 'وبلاگ LimaxAI | پلتفرم یکپارچه ابزارهای هوش مصنوعی',
  nl: 'LimaxAI Blog | Alles-in-één AI-toolplatform',
  pl: 'Blog LimaxAI | Kompleksowa platforma narzędzi AI',
  sv: 'LimaxAI-bloggen | Allt-i-ett-plattform för AI-verktyg',
  uk: 'Блог LimaxAI | Універсальна платформа AI-інструментів',
  ro: 'Blog LimaxAI | Platformă all-in-one de instrumente AI',
};
const blogSeoTitle = blogSeoTitleByLocale[currentLang] ?? blogSeoTitleByLocale.en;
---

{/* 使用 Layout 包裹内容；博客区文案来自 src/i18n/content.ts */}
<BaseLayout title={blogSeoTitle} description={blogCopy.subtitle} canonical={`${Astro.url.origin}/${currentLang}/`} currentLang={currentLang} baiduSiteVerification>
  <div hidden data-blog-build-time={buildTime} data-blog-posts-count={posts.length} aria-hidden="true" />

  <div class="bg-white py-12 border-b border-gray-100 mb-8">
    <div class="max-w-7xl mx-auto px-4 text-center sm:px-6 lg:px-8">
      <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight sm:text-5xl mb-3">
        {blogCopy.title}
      </h1>
      <p class="text-xl text-gray-500 max-w-2xl mx-auto">
        {blogCopy.subtitle}
      </p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>
    ) : (
      <div class="text-center py-20 bg-white rounded-2xl border border-dashed border-gray-300">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900">{blogCopy.noPosts}</h3>
        <p class="mt-1 text-sm text-gray-500">{blogCopy.checkBackLater}</p>
      </div>
    )}
  </div>

</BaseLayout>