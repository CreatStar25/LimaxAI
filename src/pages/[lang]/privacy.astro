---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPrivacyContent, getAllLocales } from '../../lib/pages';

export async function getStaticPaths() {
  return getAllLocales().map((lang) => {
    const content = getPrivacyContent(lang);
    return {
      params: { lang },
      props: { currentLang: lang, title: content.title, body: content.body },
    };
  });
}

const { currentLang, title, body } = Astro.props;
---

<BaseLayout title={`${title} | LimaxAI`} currentLang={currentLang}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-3xl font-bold text-gray-900 mb-6">{title}</h1>
    <div class="prose prose-gray text-gray-600 leading-relaxed">
      <p>{body}</p>
    </div>
    <p class="mt-8">
      <a href={`/${currentLang}/`} class="text-blue-600 hover:underline">← Blog</a>
    </p>
  </div>
</BaseLayout>
