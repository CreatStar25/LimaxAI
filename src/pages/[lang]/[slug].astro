---
// src/pages/[lang]/[slug].astro
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaData from '../../components/SchemaData.astro';
import { getUi } from '../../i18n/ui';

// 1. 生成所有文章的静态路径
export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  
  // 按文章标识符分组（假设相同文章在不同语言中有相同的文件名）
  const articlesBySlug = new Map();
  
  for (const entry of blogEntries) {
    const [lang, ...slugParts] = entry.slug.split('/');
    const slug = slugParts.join('/');
    const baseSlug = slugParts[slugParts.length - 1]; // 获取基本文件名
    
    if (!articlesBySlug.has(baseSlug)) {
      articlesBySlug.set(baseSlug, []);
    }
    articlesBySlug.get(baseSlug).push({ lang, slug, entry });
  }

  return blogEntries.map(entry => {
    const [lang, ...slugParts] = entry.slug.split('/');
    const slug = slugParts.join('/');
    const baseSlug = slugParts[slugParts.length - 1];
    
    // 查找同一文章的其他语言版本
    const alternateUrls: Record<string, string> = {};
    const relatedArticles = articlesBySlug.get(baseSlug) || [];
    
    for (const related of relatedArticles) {
      if (related.lang !== lang) {
        alternateUrls[related.lang] = `${Astro.site?.href || 'https://blog.limaxai.com'}/${related.lang}/${baseSlug}/`;
      }
    }

    return {
      params: { lang, slug },
      props: { 
        entry,
        alternateUrls
      },
    };
  });
}

// 2. 获取文章内容
const { entry, alternateUrls = {} } = Astro.props;
const { Content } = await entry.render();
const t = getUi(entry.data.lang);

// 格式化日期
const formattedDate = entry.data.pubDate.toLocaleDateString(entry.data.lang, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const postSlug = entry.slug.split('/').pop();
const siteBase = (Astro.site?.href ?? 'https://blog.limaxai.com').replace(/\/$/, '');
const canonical = `${siteBase}/${entry.data.lang}/${postSlug}/`;
const image = entry.data.heroImage ?? (typeof entry.data.image === 'string' ? entry.data.image : '');
const readMinutes = Math.max(1, Math.ceil(entry.body.length / 800));
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  image={image}
  canonical={canonical}
  currentLang={entry.data.lang}
  alternateUrls={alternateUrls}
>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    {/* 1. 面包屑导航 (Breadcrumbs) */}
    <nav class="flex items-center text-sm text-gray-500 mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-2">
        <li class="inline-flex items-center">
          <a href="https://www.limaxai.com" class="inline-flex items-center hover:text-blue-600 transition-colors">
            <svg class="w-3 h-3 mr-1.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            {t.navbar.home}
          </a>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <a href={`/${entry.data.lang}/`} class="ml-1 hover:text-blue-600 transition-colors">{t.navbar.blog}</a>
          </div>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-gray-900 font-medium truncate max-w-[150px] sm:max-w-xs">
              {entry.data.title}
            </span>
          </div>
        </li>
      </ol>
    </nav>

    {/* 面包屑导航结构化数据 */}
    <SchemaData 
      type="BreadcrumbList" 
      data={{
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": t.navbar.home,
            "item": "https://www.limaxai.com"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": t.navbar.blog,
            "item": `${siteBase}/${entry.data.lang}/`
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": entry.data.title,
            "item": canonical
          }
        ]
      }} 
    />

    {/* 文章头部信息 */}
    <header class="mb-10 border-b border-gray-100 pb-10">
      <div class="mb-4">
        <span class="text-blue-600 font-bold text-sm tracking-wide uppercase">
          {entry.data.tags[0]}
        </span>
      </div>

      <h1 class="text-3xl md:text-5xl font-extrabold text-gray-900 tracking-tight mb-6 leading-tight">
        {entry.data.title}
      </h1>

      <div class="flex items-center text-sm text-gray-500">
        <span class="font-medium text-gray-900">{entry.data.author}</span>
        <span class="mx-2 text-gray-300">•</span>
        <time datetime={entry.data.pubDate.toISOString()}>{formattedDate}</time>
        <span class="mx-2 text-gray-300">•</span>
        <span>{t.meta.readTime.replace('{minutes}', String(readMinutes))}</span>
      </div>
    </header>

    {/* 文章正文 */}
    <div class="prose prose-lg prose-blue mx-auto text-gray-700 leading-relaxed [&_table]:block [&_table]:w-full [&_table]:overflow-x-auto [&_table]:whitespace-nowrap sm:[&_table]:whitespace-normal">
      <Content />
    </div>

    {/* 文章结构化数据 */}
    <SchemaData 
      type="Article" 
      currentLang={entry.data.lang}
      data={{
        "headline": entry.data.title,
        "description": entry.data.description,
        "image": image,
        "author": {
          "@type": "Organization",
          "name": entry.data.author,
          "url": "https://www.limaxai.com"
        },
        "publisher": {
          "@type": "Organization",
          "name": "LimaxAI",
          "logo": {
            "@type": "ImageObject",
            "url": `${siteBase}/logo.png`,
            "width": 512,
            "height": 512
          }
        },
        "datePublished": entry.data.pubDate.toISOString(),
        "dateModified": entry.data.pubDate.toISOString(),
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": canonical
        },
        "wordCount": entry.body.length,
        "timeRequired": `PT${readMinutes}M`,
        "articleSection": entry.data.tags[0] || t.meta.articleSection
      }} 
    />

  </article>
</BaseLayout>
