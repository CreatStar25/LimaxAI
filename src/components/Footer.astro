---
// src/components/Footer.astro
// 左侧：品牌区；右侧：5 列导航（AI Image, AI Video, AI Music, AI Tools, Company）
import { getUi } from '../i18n/ui';

const { currentLang = 'en' } = Astro.props;
const currentYear = new Date().getFullYear();
const t = getUi(currentLang).footer;

const columns = [
  {
    titleKey: 'aiImage' as const,
    links: [
      { labelKey: 'midjourney' as const, href: 'https://midjourney.cfd' },
      { labelKey: 'nanoBananaPro' as const, href: 'https://nanobanana-pro.vip' },
      { labelKey: 'nanoBanana2' as const, href: 'https://nanobananapro.hk' },
      { labelKey: 'nanoBanana3' as const, href: 'https://nanobanana3.top' },
    ],
  },
  {
    titleKey: 'aiVideo' as const,
    links: [
      { labelKey: 'seedance20' as const, href: 'https://seedance22.com' },
      { labelKey: 'seedance15' as const, href: 'https://seedance2.hk' },
      { labelKey: 'veo3' as const, href: 'https://veo3.hk' },
      { labelKey: 'happyHorse1' as const, href: 'https://happyhorse.fans/' },
      { labelKey: 'happyHorse2' as const, href: 'https://happy-horse.hk/' },
    ],
  },
  {
    titleKey: 'aiMusic' as const,
    links: [
      { labelKey: 'suno' as const, href: 'https://sunoai.me/' },
      { labelKey: 'sunoHK' as const, href: 'https://suno.hk/' },
      { labelKey: 'udio' as const, href: 'https://udio.hk/' },
    ],
  },
  {
    titleKey: 'aiTools' as const,
    links: [
      { labelKey: 'limaxai' as const, href: 'https://www.limaxai.com/' },
      { labelKey: 'deepseek4' as const, href: 'https://deepseek4.hk' },
      { labelKey: 'notebooklm' as const, href: 'https://notebooklm.vip' },
      { labelKey: 'openclaw' as const, href: 'https://openclawd.hk' },
      { labelKey: 'gemini30' as const, href: 'https://gemini3.hk' },
      { labelKey: 'geminiWatermarkErase' as const, href: 'https://geminiwatermarkerase.com/' },
    ],
  },
  {
    titleKey: 'company' as const,
    links: [
      { labelKey: 'blog' as const, href: `/${currentLang}/` },
      { labelKey: 'about' as const, href: `/${currentLang}/about/` },
      { labelKey: 'privacy' as const, href: `/${currentLang}/privacy/` },
      { labelKey: 'terms' as const, href: `/${currentLang}/terms/` },
      { labelKey: 'api' as const, href: 'https://api.limaxai.com/', external: true },
    ],
  },
];

const columnTitles: Record<keyof typeof t.columns, string> = t.columns;
const linkLabels: Record<keyof typeof t.links, string> = t.links;
---

<footer class="bg-gray-50 border-t border-gray-200 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-8">
    <div class="flex flex-col lg:flex-row lg:gap-12 gap-10">
      {/* 左侧：品牌区 - Logo、标题、简介 */}
      <div class="lg:max-w-sm flex-shrink-0">
        <a href={`/${currentLang}/`} class="inline-flex items-center gap-2 mb-3">
          <img src="https://img.limaxai.com/aiweb/limaxai.png" alt="LimaxAI Logo" class="h-8 w-8 object-contain" width="32" height="32" loading="lazy" decoding="async" />
          <span class="text-xl font-bold text-gray-900">{t.brand.title}</span>
        </a>
        <p class="text-gray-500 text-sm leading-relaxed">
          {t.brand.intro}
        </p>
      </div>

      {/* 右侧：五列导航 */}
      <div class="flex-1 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-8 lg:gap-10">
        {columns.map((col) => (
          <div>
            <h3 class="text-base font-bold text-gray-900 mb-4">
              {columnTitles[col.titleKey]}
            </h3>
            <ul class="space-y-3">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-gray-500 hover:text-gray-900 transition-colors"
                    target={link.external ? '_blank' : undefined}
                    rel={link.external ? 'noopener noreferrer' : undefined}
                  >
                    {linkLabels[link.labelKey]}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-10 pt-8 border-t border-gray-200">
      <p class="text-sm text-gray-400">
        &copy; {currentYear} {t.brand.title}. {t.copyright}
      </p>
    </div>
  </div>
</footer>
